SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SERVER_ADDRESS=127.0.0.1

SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/finventory
SPRING_DATASOURCE_USERNAME=finventory
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

APPLICATION_JWT_SECRET_KEY=CHANGE_ME_BASE64
APPLICATION_JWT_EXPIRATION_MS=86400000

APPLICATION_CORS_ALLOWED_ORIGIN_PATTERNS=https://example.com,http://localhost:*

APPLICATION_UPLOADS_DIR=/var/lib/finventory/uploads
